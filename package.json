{
  "name": "paul-hicks-nz.github.io",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --cwd packages/site dev",
    "build": "bun run --cwd packages/site build",
    "preview": "bun run --cwd packages/site preview",
    "lint": "bun --elide-lines=0 run --filter='@site/*' lint",
    "test": "bun --elide-lines=0 run --filter='@site/test-*' test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.0.0",
    "@happy-dom/global-registrator": "^20.8.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.1.2",
    "happy-dom": "^20.8.9"
  }
}
